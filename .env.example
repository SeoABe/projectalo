# 로컬 개발용(.env) / Vercel 환경변수 동일하게 설정
# ── Supabase ──────────────────────────────────────────────
# Supabase 대시보드 > Project Settings > Database > Connection string > "Transaction pooler"(포트 6543)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
# Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...        # 공개용(프론트로 전달됨)

# ── Naver 뉴스 API (재발급 권장) ──────────────────────────
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# ── Cron 보호용 임의 시크릿 ───────────────────────────────
CRON_SECRET=set-a-long-random-string
